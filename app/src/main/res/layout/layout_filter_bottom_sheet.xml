<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/app_dialog_background"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_title"
            android:textColor="@color/verde_claro_pixel"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnResetFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/filter_clear_all"
            android:textColor="@color/amarillo_claro_pixel"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- SORT Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_sort_by"
                android:textColor="@color/blanco_intermedio"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgSort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_popularity"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_claro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precio: Bajo a Alto"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Más nuevos"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- PLATFORM Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="PLATAFORMAS"
                android:textColor="@color/blanco_intermedio"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgPlatforms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PS5"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xbox Series"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nintendo Switch"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_claro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PC Master Race"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- CATEGORIES Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CATEGORÍAS"
                android:textColor="@color/blanco_intermedio"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acción"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aventura"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_claro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RPG"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
                <com.google.android.material.chip.Chip
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deportes"
                    app:chipBackgroundColor="@color/negro_oscuro"
                    android:textColor="@color/blanco_intermedio"
                    app:chipStrokeColor="@color/verde_oscuro_pixel"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- PRICE RANGE Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RANGO DE PRECIO"
                    android:textColor="@color/blanco_intermedio"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvPriceRangeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="$0 - $120"
                    android:textColor="@color/verde_claro_pixel"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/priceSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:valueFrom="0.0"
                android:valueTo="200.0"
                app:values="@array/initial_range_values"
                app:thumbColor="@color/verde_claro_pixel"
                app:trackColorActive="@color/blanco_claro"
                app:trackColorInactive="@color/verde_oscuro_pixel" />

            <!-- YEAR Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AÑO DE LANZAMIENTO"
                android:textColor="@color/blanco_intermedio"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/yearSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:valueFrom="2015"
                android:valueTo="2024"
                android:stepSize="1"
                android:value="2020"
                app:thumbColor="@color/verde_claro_pixel"
                app:trackColorActive="@color/blanco_claro"
                app:trackColorInactive="@color/verde_oscuro_pixel" />

            <!-- RATING Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="VALORACIÓN MÍNIMA"
                android:textColor="@color/blanco_intermedio"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <RatingBar
                android:id="@+id/ratingFilter"
                style="@style/Widget.AppCompat.RatingBar.Indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:numStars="5"
                android:rating="4"
                android:progressTint="@color/verde_claro_pixel"
                android:secondaryProgressTint="@color/verde_oscuro_pixel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyFilters"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="APLICAR FILTROS"
                android:textColor="@color/negro_oscuro"
                android:textStyle="bold"
                android:background="@drawable/btn_primary_color"
                app:backgroundTint="@null" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>