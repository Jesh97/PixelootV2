<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieSuccess"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:lottie_autoPlay="true"
        app:lottie_fileName="coin_lottie.json"
        app:lottie_loop="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/order_success_title"
        android:textColor="@color/verde_claro_pixel"
        android:textSize="28sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/order_success_desc"
        android:textColor="@color/blanco_claro"
        android:textSize="16sp"
        android:textAlignment="center"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadReceipt"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:text="DESCARGAR RECIBO PDF"
        android:textColor="@color/negro_oscuro"
        android:textStyle="bold"
        android:background="@drawable/btn_primary_color"
        app:backgroundTint="@null"
        app:icon="@drawable/icon_download"
        app:iconTint="@color/negro_oscuro"
        app:iconGravity="textStart"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="@string/order_back_home"
        android:textColor="@color/verde_claro_pixel"
        android:textStyle="bold"
        android:background="@drawable/btn_secondary_color"
        app:backgroundTint="@null"/>

</LinearLayout>
