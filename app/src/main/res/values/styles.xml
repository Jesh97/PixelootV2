<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Styles -->
    <style name="AppText" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textColor">@color/blanco_claro</item>
    </style>

    <style name="AppText.Title">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/verde_claro_pixel</item>
    </style>

    <style name="AppText.Subtitle">
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/blanco_claro</item>
    </style>

    <style name="AppText.Body">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/blanco_intermedio</item>
    </style>

    <style name="AppText.Caption">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/blanco_intermedio</item>
        <item name="android:alpha">0.7</item>
    </style>

    <!-- Button Styles -->
    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/card_corner_radius</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="AppButton.Primary">
        <item name="android:background">@drawable/bg_button_primary_gradient</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/negro_oscuro</item>
        <item name="rippleColor">@color/verde_oscuro_pixel</item>
    </style>

    <style name="AppButton.Secondary">
        <item name="backgroundTint">@color/negro_intermedio</item>
        <item name="android:textColor">@color/blanco_claro</item>
        <item name="strokeColor">@color/verde_claro_pixel</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Card Styles -->
    <style name="AppCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/negro_intermedio</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">4dp</item>
    </style>

</resources>
