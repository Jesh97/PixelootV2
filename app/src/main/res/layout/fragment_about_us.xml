<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro"
    android:fillViewport="true"
    tools:context=".AboutUsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Top Header Image/Logo -->
        <View
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/app_gradient"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgAboutLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/pixel_root_icono_claro"
            app:layout_constraintBottom_toBottomOf="@id/headerBg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/headerBg" />

        <!-- Velva Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVelva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-30dp"
            app:cardBackgroundColor="@color/negro_oscuro"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/headerBg"
            app:strokeColor="@color/verde_claro_pixel"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_us_velva"
                    android:textColor="@color/verde_claro_pixel"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/about_velva_desc"
                    android:textColor="@color/blanco_intermedio"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pixel Root Section -->
        <TextView
            android:id="@+id/titlePixelRoot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Pixel Root"
            android:textColor="@color/blanco_claro"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardVelva" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="4dp"
            android:background="@color/verde_claro_pixel"
            app:layout_constraintStart_toStartOf="@id/titlePixelRoot"
            app:layout_constraintTop_toBottomOf="@id/titlePixelRoot" />

        <TextView
            android:id="@+id/descPixelRoot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:text="@string/about_pixelroot_desc"
            android:textColor="@color/blanco_intermedio"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titlePixelRoot" />

        <!-- Branches Shortcut -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToBranches"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/about_our_branches"
            android:textColor="@color/negro_oscuro"
            android:textStyle="bold"
            android:background="@drawable/btn_primary_color"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"
            app:icon="@drawable/icon_branch"
            app:iconGravity="textStart"
            app:iconTint="@color/negro_oscuro"
            app:layout_constraintTop_toBottomOf="@id/descPixelRoot" />

        <!-- Products Shortcut -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToProducts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/about_our_products"
            android:textColor="@color/verde_claro_pixel"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary_color"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"
            app:icon="@drawable/icon_plataform_game"
            app:iconGravity="textStart"
            app:iconTint="@color/verde_claro_pixel"
            app:layout_constraintTop_toBottomOf="@id/btnGoToBranches" />

        <!-- Team Section -->
        <TextView
            android:id="@+id/titleTeam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:text="@string/about_dev_team"
            android:textColor="@color/blanco_claro"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnGoToProducts" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/titleTeam">

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/icon_default_profile"
                app:civ_border_color="@color/verde_claro_pixel"
                app:civ_border_width="2dp" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/icon_default_profile"
                app:civ_border_color="@color/verde_claro_pixel"
                app:civ_border_width="2dp" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/icon_default_profile"
                app:civ_border_color="@color/verde_claro_pixel"
                app:civ_border_width="2dp" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/icon_default_profile"
                app:civ_border_color="@color/verde_claro_pixel"
                app:civ_border_width="2dp" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/icon_default_profile"
                app:civ_border_color="@color/verde_claro_pixel"
                app:civ_border_width="2dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>