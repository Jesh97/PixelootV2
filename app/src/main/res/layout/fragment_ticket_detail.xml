<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerTicketDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_filter_button"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/negro_oscuro"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/txtDetailId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:text="Ticket #TK-9283"
            android:textColor="@color/verde_claro_pixel"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_timer_box"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="ABIERTO"
            android:textColor="@color/blanco_claro"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerTicketDetail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_gaming"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ticket_details_label"
                    android:textColor="@color/blanco_intermedio"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/txtDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Error en descarga de código digital"
                    android:textColor="@color/verde_claro_pixel"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="El código recibido para Neon Abyss II no es válido en la tienda de PSN. Por favor verificar el envío."
                    android:textColor="@color/blanco_intermedio"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/verde_oscuro_pixel" />

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pedido asociado:" android:textColor="@color/blanco_intermedio" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtDetailOrder" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="#PR-85920" android:textColor="@color/verde_claro_pixel" android:textSize="13sp" android:textStyle="bold"/>
                </RelativeLayout>
            </LinearLayout>

            <!-- Navigation Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewTimeline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/ticket_detail_timeline"
                android:textColor="@color/blanco_claro"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary_color"
                app:backgroundTint="@null"
                app:icon="@drawable/icon_time_line"
                app:iconTint="@color/verde_claro_pixel"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAttachments"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/ticket_attachments"
                android:textColor="@color/blanco_claro"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary_color"
                app:backgroundTint="@null"
                app:icon="@drawable/icon_save"
                app:iconTint="@color/verde_claro_pixel"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewChat"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/ticket_detail_chat"
                android:textColor="@color/negro_oscuro"
                android:textStyle="bold"
                android:background="@drawable/btn_primary_color"
                app:backgroundTint="@null"
                app:icon="@drawable/icon_chat"
                app:iconTint="@color/negro_oscuro"/>

            <!-- Sección Calificación (solo visible si el ticket está cerrado) -->
            <LinearLayout
                android:id="@+id/sectionCalificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_gaming"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/txtCalificacionTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Califica la atención recibida"
                    android:textColor="@color/verde_claro_pixel"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/ratingBarCalificacion"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    android:progressTint="@color/verde_claro_pixel"
                    android:secondaryProgressTint="@color/verde_oscuro_pixel" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutComentarioCalificacion"
                    style="@style/Widget.PixelRootApp.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:hintEnabled="true"
                    android:hint="Comentario (opcional)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComentarioCalificacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:minLines="3"
                        android:inputType="textMultiLine"
                        android:textColor="@color/blanco_claro"
                        android:textColorHint="@color/blanco_intermedio" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnviarCalificacion"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Enviar calificación"
                    android:textColor="@color/negro_oscuro"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary_color"
                    app:backgroundTint="@null" />

                <TextView
                    android:id="@+id/txtCalificacionEnviada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="¡Gracias por calificar nuestra atención!"
                    android:textColor="@color/blanco_intermedio"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReopenTicket"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/ticket_reopen"
                android:textColor="@color/verde_claro_pixel"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary_color"
                app:backgroundTint="@null"
                android:visibility="gone"
                app:icon="@drawable/icon_branch"
                app:iconTint="@color/verde_claro_pixel"/>

            <Space android:layout_width="match_parent" android:layout_height="40dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>