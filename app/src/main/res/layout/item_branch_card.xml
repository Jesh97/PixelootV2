<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_medium"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_medium"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/imgBranch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/flyer_pixel"
                android:contentDescription="Sucursal" />
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/icon_branch"
                app:tint="@color/blanco_claro"
                android:contentDescription="Icono" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_medium"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtBranchName"
                style="@style/AppText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PixelHouse Norte" />

            <TextView
                android:id="@+id/txtBranchAddress"
                style="@style/AppText.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Av. Bolognesi 2342"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/icon_ubication"
                    app:tint="@color/verde_claro_pixel"
                    android:contentDescription="Mapa" />
                <TextView
                    android:id="@+id/txtDistance"
                    style="@style/AppText.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="1.2 km de distancia"
                    android:textStyle="bold"
                    android:alpha="1" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnViewOnMap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_timer_box"
            android:src="@drawable/icon_ubication_gps"
            app:tint="@color/verde_claro_pixel"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Ver en mapa" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
