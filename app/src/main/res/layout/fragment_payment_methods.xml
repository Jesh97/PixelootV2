<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerPaymentMethods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_large"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/AppText.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Medios de Pago"
            android:textSize="20sp" />

        <ImageButton
            android:id="@+id/btnAddCard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_filter_button"
            android:src="@drawable/icon_add_circle"
            app:tint="@color/negro_oscuro"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Agregar tarjeta"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSavedCards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="@dimen/spacing_large"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerPaymentMethods"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_saved_card"/>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvSavedCards"
        app:layout_constraintBottom_toBottomOf="@id/rvSavedCards"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/icon_payment"
            app:tint="@color/verde_oscuro_pixel"
            android:contentDescription="Sin tarjetas"/>

        <TextView
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="No tienes tarjetas guardadas"
            android:textAlignment="center"/>

        <TextView
            style="@style/AppText.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Marca &quot;Guardar para futuras compras&quot; al pagar para que aparezcan aquí"
            android:textAlignment="center"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>