<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <RelativeLayout
        android:id="@+id/headerAttachments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Archivos Adjuntos"
            android:textColor="@color/verde_claro_pixel"
            android:textSize="28sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAttachments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintBottom_toTopOf="@id/btnAddAttachment"
        app:layout_constraintTop_toBottomOf="@id/headerAttachments"
        tools:listitem="@layout/item_gallery_thumbnail" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddAttachment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:text="SUBIR ARCHIVO"
        android:textColor="@color/negro_oscuro"
        android:textStyle="bold"
        android:background="@drawable/btn_primary_color"
        app:backgroundTint="@null"
        app:icon="@drawable/icono_upload"
        app:iconTint="@color/negro_oscuro"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>