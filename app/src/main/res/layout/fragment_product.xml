<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/product_category_videojuegos"
                android:textColor="@color/verde_claro_pixel"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnOpenFilters"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_filter_button"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_filter"
                app:tint="@color/negro_oscuro" />
        </RelativeLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/searchProductLayout"
            style="@style/Widget.PixelRootApp.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_pixel"
            app:startIconTint="@color/verde_claro_pixel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/product_search_hint"
                android:padding="16dp"
                android:singleLine="true"
                android:textColor="@color/blanco_claro"
                android:textColorHint="@color/blanco_intermedio"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Games Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerProduct"
        app:spanCount="2"
        tools:listitem="@layout/item_game_card_vertical" />

</androidx.constraintlayout.widget.ConstraintLayout>