<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MapsFragment" />

    <!-- Top Overlay Search/Back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackFromMap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_timer_box"
            android:backgroundTint="@color/negro_oscuro"
            android:src="@drawable/ic_chevron_left"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:tint="@color/verde_claro_pixel" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_timer_box"
            android:backgroundTint="@color/negro_oscuro"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/maps_title"
                android:textColor="@color/blanco_claro"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Selected Branch Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSelectedBranch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="visible"
        app:cardBackgroundColor="@color/negro_oscuro"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txtSelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PixelHouse Centro"
                    android:textColor="@color/blanco_claro"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/maps_open_status"
                    android:textColor="@color/verde_claro_pixel"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:id="@+id/txtSelAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="C. Elías Aguirre 123, Chiclayo"
                android:textColor="@color/blanco_intermedio"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNavigate"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/maps_directions_btn"
                    android:textColor="@color/negro_oscuro"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary_color"
                    app:backgroundTint="@null" />

                <ImageButton
                    android:id="@+id/btnCallBranch"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/btn_secondary_color"
                    android:backgroundTint="@null"
                    android:src="@drawable/icon_call"
                    app:tint="@color/verde_claro_pixel"
                    android:padding="12dp"
                    android:scaleType="fitCenter" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>