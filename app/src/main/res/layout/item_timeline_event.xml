<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_small">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_filter_button" />
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/verde_oscuro_pixel" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_medium"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtTimelineTitle"
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ticket Creado"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/txtTimelineDesc"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tu reporte ha sido recibido."
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/txtTimelineTime"
            style="@style/AppText.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="24 Oct, 10:30 AM"
            android:textColor="@color/verde_claro_pixel"
            android:alpha="1" />
    </LinearLayout>

</LinearLayout>
