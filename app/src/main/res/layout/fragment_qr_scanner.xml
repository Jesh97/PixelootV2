<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_oscuro">

    <!-- Scanner View -->
    <com.journeyapps.barcodescanner.CompoundBarcodeView
        android:id="@+id/barcodeScanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_viewfinder_laser="@color/verde_claro_pixel"
        app:zxing_viewfinder_mask="#AA000000" />

    <!-- Overlay Square with border -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/viewFinder"
        android:layout_width="260dp"
        android:layout_height="260dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:strokeColor="@color/verde_claro_pixel"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Instruction Header -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:background="@drawable/bg_timer_box"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/icon_readqr"
            app:tint="@color/verde_claro_pixel" />

        <TextView
            android:id="@+id/txtInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/qr_scanner_instructions"
            android:textColor="@color/blanco_claro"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Status Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="SISTEMA DE ESCANEO QR ACTIVO"
        android:textColor="@color/verde_claro_pixel"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewFinder" />

    <!-- Larger Back Button with Icon -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelScan"
        style="@style/AppButton.Primary"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginBottom="48dp"
        android:text="@string/qr_scanner_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
